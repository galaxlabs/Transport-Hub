# Base URL of your Frappe backend. For production this should point to your
# Frappe site hosting TSS. Leave empty if the frontend is served from the
# same live domain as the Frappe backend.
VITE_FRAPPE_URL=https://trip.galaxylabs.online

# Optional: force website bookings into a specific Base Company.
# If omitted, TSS will use the first active Base Company.
VITE_TSS_BASE_COMPANY=
